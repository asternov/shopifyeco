{% schema %}
{
  "name": "New Arrivals (custom)",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main image (left side)"
    },
    {
      "type": "url",
      "id": "main_image_link",
      "label": "Main image link (optional)",
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "image_picker",
      "id": "secondary_image_1",
      "label": "Secondary image 1"
    },
    {
      "type": "url",
      "id": "secondary_image_1_link",
      "label": "Secondary image 1 link (optional)",
    },
    {
      "type": "text",
      "id": "caption_1",
      "label": "Caption for image 1"
    },
    {
      "type": "image_picker",
      "id": "secondary_image_2",
      "label": "Secondary image 2"
    },
    {
      "type": "url",
      "id": "secondary_image_2_link",
      "label": "Secondary image 2 link (optional)",
    },
    {
      "type": "text",
      "id": "caption_2",
      "label": "Caption for image 2"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals (custom)"
    }
  ]
}
{% endschema %}

{%- liquid
  assign main_img = section.settings.main_image
  assign sec_img_1 = section.settings.secondary_image_1
  assign sec_img_2 = section.settings.secondary_image_2
  assign main_sizes = '(min-width: 990px) 50vw, 100vw'
  assign sec_sizes = '(min-width: 990px) 25vw, 50vw'
  assign main_widths = '350, 450, 550, 700, 900, 1100, 1400'
  assign sec_widths = '175, 250, 350, 450, 550, 700'
-%}

<div class="new-arrivals-section wrapper--full-padded section-padding">
  <div class="new-arrivals-section__main">
    {% if main_img != blank %}
      {%- assign main_height = main_img.width | divided_by: main_img.aspect_ratio | round -%}
      {% if section.settings.main_image_link != blank %}
        <a href="{{ section.settings.main_image_link }}" class="new-arrivals-section__main-image-link">
      {% endif %}
        {{ main_img | image_url: width: 700 | image_tag:
          loading: 'lazy',
          sizes: main_sizes,
          widths: main_widths,
          alt: main_img.alt | default: 'Main image',
          class: 'new-arrivals-section__main-image',
          width: main_img.width,
          height: main_height
        }}
      {% if section.settings.main_image_link != blank %}
        </a>
      {% endif %}
    {% endif %}
  </div>
  <div class="new-arrivals-section__right">
    <div class="new-arrivals-section__right-content">
    {% if section.settings.title != blank %}
      <p role="heading" aria-level="2" class="new-arrivals-section__title">{{ section.settings.title }}</p>
    {% endif %}
    {% if section.settings.subtitle != blank %}
      <h3 class="new-arrivals-section__subtitle">{{ section.settings.subtitle }}</h3>
    {% endif %}
    {% if section.settings.description != blank %}
      <div class="new-arrivals-section__description">{{ section.settings.description }}</div>
    {% endif %}

    <div class="new-arrivals-section__secondary-images">
      <div class="new-arrivals-section__secondary-block">
        {% if sec_img_1 != blank %}
          {%- assign sec1_height = sec_img_1.width | divided_by: sec_img_1.aspect_ratio | round -%}
          {% if section.settings.secondary_image_1_link != blank %}
            <a href="{{ section.settings.secondary_image_1_link }}" class="new-arrivals-section__secondary-link">
          {% endif %}
            {{ sec_img_1 | image_url: width: 350 | image_tag:
              loading: 'lazy',
              sizes: sec_sizes,
              widths: sec_widths,
              alt: sec_img_1.alt | default: 'Secondary image 1',
              class: 'new-arrivals-section__secondary-image',
              width: sec_img_1.width,
              height: sec1_height
            }}
          {% if section.settings.secondary_image_1_link != blank %}
            </a>
          {% endif %}
        {% endif %}
        {% if section.settings.caption_1 != blank %}
          <div class="new-arrivals-section__caption">{{ section.settings.caption_1 }}</div>
        {% endif %}
      </div>
      <div class="new-arrivals-section__secondary-block">
        {% if sec_img_2 != blank %}
          {%- assign sec2_height = sec_img_2.width | divided_by: sec_img_2.aspect_ratio | round -%}
          {% if section.settings.secondary_image_2_link != blank %}
            <a href="{{ section.settings.secondary_image_2_link }}" class="new-arrivals-section__secondary-link">
          {% endif %}
            {{ sec_img_2 | image_url: width: 350 | image_tag:
              loading: 'lazy',
              sizes: sec_sizes,
              widths: sec_widths,
              alt: sec_img_2.alt | default: 'Secondary image 2',
              class: 'new-arrivals-section__secondary-image',
              width: sec_img_2.width,
              height: sec2_height
            }}
          {% if section.settings.secondary_image_2_link != blank %}
            </a>
          {% endif %}
        {% endif %}
        {% if section.settings.caption_2 != blank %}
          <div class="new-arrivals-section__caption">{{ section.settings.caption_2 }}</div>
        {% endif %}
      </div>
    </div>
    </div>

  </div>
</div>
