<!-- /sections/section-breadcrumbs.liquid -->

{%- liquid
  assign breadcrumbs_alignment = section.settings.breadcrumbs_alignment
  assign pt = section.settings.padding_top
  assign pb = section.settings.padding_bottom
-%}

<section
  class="section-breadcrumbs section-breadcrumbs--{{ section.settings.separator_style }}"
  data-section-id="{{ section.id }}"
  data-section-type="breadcrumbs"
  style="padding-top: {{ pt }}px; padding-bottom: {{ pb }}px;"
>
  <div class="{{ section.settings.width }}">
    <div class="breadcrumbs-wrapper text-{{ breadcrumbs_alignment }}">
      {%- render 'breadcrumbs' -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Breadcrumbs",
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "default": "wrapper",
      "options": [
        { "value": "wrapper--full-padded", "label": "Full width padded" },
        { "value": "wrapper", "label": "Normal" },
        { "value": "wrapper--narrow", "label": "Narrow" }
      ]
    },
    {
      "type": "select",
      "id": "breadcrumbs_alignment",
      "label": "Alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "separator_style",
      "label": "Separator style",
      "default": "dot",
      "options": [
        { "value": "dot", "label": "Dot (•)" },
        { "value": "slash", "label": "Slash (/)" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "category": "Navigation"
    }
  ]
}
{% endschema %}
